    "openbb": {
      "enabled": false,
      "fetch_filings": false,
      "filings_provider": "sec",
      "watchlists": []
    },
    "ossinsight": {
      "enabled": true,
      "period": "past_24_hours",
      "languages": ["All", "Python", "TypeScript"],
      "keywords": ["AI", "agent", "LLM", "open source"],
      "min_stars": 50,
      "max_items": 20
    }
  },
  "filtering": {
    "ai_score_threshold": 6.0,
    "time_window_hours": 24,
    "max_items": 20,
    "category_groups": {
      "ai-agent": {
        "name": "AI Agent",
        "limit": 10,
        "categories": ["ai-tools", "ai-news"]
      },
      "open-source": {
        "name": "开源动态",
        "limit": 10,
        "categories": ["github-trending"]
      },
      "indie-business": {
        "name": "独立开发",
        "limit": 10,
        "categories": ["indie-maker", "startup-news"]
      }
    },
    "default_group": "other",
    "default_group_limit": 10
  },
  "webhook": {
    "enabled": false
  }
}
